# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo servidor si usas scripts/admin
# SUPABASE_SERVICE_ROLE_KEY=

# URL pública de la app (enlaces en correos de invitación). En local:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Opcional: misma URL solo para el servidor (si no usas NEXT_PUBLIC_*)
# SITE_URL=http://localhost:3000

# --- SMTP (Nodemailer, invitaciones de equipo) ---
# Gmail: usa "contraseña de aplicación", sin espacios en SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Opcional: remitente (por defecto = SMTP_USER)
# SMTP_FROM="Diwhat <tu@gmail.com>"
# Puerto 465 con SSL directo:
# SMTP_SECURE=1

# --- Worker WhatsApp ---
WHATSAPP_WORKER_URL=http://127.0.0.1:8787
WHATSAPP_WORKER_SECRET=
# Alertas por email para mensajes inbound (worker). Requiere SMTP_*.
# WHATSAPP_INBOUND_EMAIL_ALERTS=1
